# Copiar este archivo a .env y completar con tus credenciales reales.
# .env nunca debe subirse al repositorio (ya esta en .gitignore).

# --- OpenAI ---
# Tu API key de https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# Modelo para los agentes (gpt-4o-mini es mas economico para clase)
OPENAI_MODEL=gpt-4o-mini

# Modelo para vision (gpt-4o tiene capacidad multimodal)
OPENAI_VISION_MODEL=gpt-4o

# --- Langfuse ---
# Obtener en https://cloud.langfuse.com -> Settings -> API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Flags de ejecucion ---
# PIM4_USE_REAL_API=1 activa llamadas reales a OpenAI (default: mock)
PIM4_USE_REAL_API=0
# PIM4_USE_LANGFUSE=1 activa envio de trazas a Langfuse (default: solo local)
PIM4_USE_LANGFUSE=0
